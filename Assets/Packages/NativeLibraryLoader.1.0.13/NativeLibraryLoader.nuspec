<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>NativeLibraryLoader</id>
    <version>1.0.13</version>
    <authors>Eric Mellino</authors>
    <projectUrl>https://github.com/mellinoe/nativelibraryloader</projectUrl>
    <description>Contains the NativeLibrary type, useful for loading native shared libraries and retrieving function pointers.</description>
    <repository url="https://github.com/mellinoe/nativelibraryloader" />
    <dependencies>
      <group targetFramework=".NETStandard2.0">
        <dependency id="Microsoft.Extensions.DependencyModel" version="2.0.3" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>